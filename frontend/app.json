{
  "expo": {
    "name": "Quickpost",
    "slug": "quickpost",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "quickpost",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.yourapp.quickpost",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Quickpost needs camera access to take photos for your social posts",
        "NSPhotoLibraryUsageDescription": "Quickpost needs photo access to create and share social posts",
        "NSPhotoLibraryAddUsageDescription": "Quickpost saves your edited post images to your photo library"
      }
    },
    "android": {
      "package": "com.yourapp.quickpost",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4f46e5"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Quickpost needs photo access to create social posts",
          "cameraPermission": "Quickpost needs camera access to take photos for posts"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4f46e5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
