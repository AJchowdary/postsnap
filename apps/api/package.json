{
  "name": "postsnap-api",
  "version": "1.0.0",
  "description": "PostSnap Node.js Express API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec \"node -r ts-node/register src/index.ts\" --ext ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "start:worker": "node dist/jobs/workerProcess.js",
    "worker": "node -r ts-node/register src/jobs/workerProcess.ts",
    "test": "jest --forceExit",
    "migrate": "node -r ts-node/register src/db/runMigrations.ts",
    "token:a": "node scripts/get-token.js A",
    "token:b": "node scripts/get-token.js B",
    "verify:ownership": "node scripts/verify-ownership.js",
    "verify:ratelimit": "node scripts/verify-ratelimit.js"
  },
  "dependencies": {
    "@sentry/node": "^8.0.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.47.10",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "openai": "^4.77.0",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongodb": "^4.0.7",
    "@types/node": "^22.10.0",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ]
  }
}
